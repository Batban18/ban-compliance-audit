{
  "mcpServers": {
    "framework-server": {
      "command": "python",
      "args": ["servers/framework_server.py", "--mode", "production", "--log-level", "INFO"],
      "description": "Manages SOC2, ISO27001, HIPAA, GDPR compliance frameworks and control catalogs",
      "version": "1.2.0",
      "protocol": "2024-11-05",
      "trust": false,
      "env": {
        "FRAMEWORK_DB": "sqlite:///compliance.db",
        "FRAMEWORK_LOG_LEVEL": "INFO",
        "FRAMEWORK_CACHE_TTL": "3600",
        "FRAMEWORK_MAX_CONTROLS": "500"
      },
      "tools": ["list_frameworks", "get_controls", "get_control_detail", "search_controls"]
    },
    "evidence-server": {
      "httpUrl": "http://localhost:5001/mcp",
      "timeout": 60000,
      "trust": false,
      "description": "Collects, stores and manages audit evidence linked to compliance controls",
      "version": "1.1.0",
      "protocol": "2024-11-05",
      "headers": {
        "X-API-Version": "v1",
        "X-Service-Name": "evidence-server",
        "X-Max-File-Size": "10MB"
      },
      "env": {
        "EVIDENCE_STORAGE_PATH": "./evidence",
        "EVIDENCE_MAX_FILE_SIZE_MB": "10",
        "EVIDENCE_ALLOWED_TYPES": "pdf,png,jpg,xlsx,docx"
      },
      "tools": ["upload_evidence", "list_evidence", "get_evidence", "delete_evidence", "tag_evidence"]
    },
    "audit-server": {
      "httpUrl": "http://localhost:5002/mcp",
      "timeout": 30000,
      "trust": true,
      "description": "Runs automated compliance checks and scores controls against frameworks",
      "version": "2.0.0",
      "protocol": "2024-11-05",
      "headers": {
        "Authorization": "Bearer audit-service-token",
        "X-API-Version": "v2",
        "X-Audit-Mode": "strict"
      },
      "env": {
        "AUDIT_DB": "sqlite:///compliance.db",
        "AUDIT_LOG_LEVEL": "INFO",
        "AUDIT_MAX_RETRIES": "3",
        "AUDIT_PASS_THRESHOLD": "0.8"
      },
      "tools": ["run_audit_check", "run_full_audit", "get_audit_score", "get_audit_history", "get_failing_controls"]
    },
    "policy-server": {
      "command": "python",
      "args": ["servers/policy_server.py", "--strict-mode", "--version", "v2"],
      "description": "Manages company security policies, versions and approval workflows",
      "version": "1.0.0",
      "protocol": "2024-11-05",
      "trust": false,
      "env": {
        "POLICY_STORE": "sqlite:///compliance.db",
        "POLICY_APPROVAL_REQUIRED": "true",
        "POLICY_MAX_VERSIONS": "10",
        "POLICY_REVIEW_CYCLE_DAYS": "365"
      },
      "tools": ["create_policy", "get_policy", "list_policies", "update_policy", "approve_policy", "get_policy_version_history"]
    },
    "vendor-server": {
      "httpUrl": "http://localhost:5003/mcp",
      "timeout": 45000,
      "trust": false,
      "description": "Third-party vendor risk assessment and management",
      "version": "1.3.0",
      "protocol": "2024-11-05",
      "headers": {
        "Authorization": "Bearer vendor-service-token",
        "X-Risk-Threshold": "high",
        "X-API-Version": "v1"
      },
      "env": {
        "VENDOR_DB": "sqlite:///compliance.db",
        "VENDOR_RISK_HIGH_THRESHOLD": "7",
        "VENDOR_ASSESSMENT_CYCLE_DAYS": "180"
      },
      "tools": ["add_vendor", "list_vendors", "get_vendor", "update_vendor_risk", "add_vendor_assessment", "list_high_risk_vendors", "get_vendors_missing_assessment"]
    },
    "report-server": {
      "command": "python",
      "args": ["servers/report_server.py", "--format", "pdf", "--output-dir", "./reports"],
      "description": "Generates audit-ready compliance reports and executive summaries",
      "version": "1.5.0",
      "protocol": "2024-11-05",
      "trust": true,
      "env": {
        "REPORT_OUTPUT_DIR": "./reports",
        "SMTP_HOST": "smtp.gmail.com",
        "SMTP_PORT": "587",
        "SMTP_USE_TLS": "true",
        "SMTP_USERNAME": "reports@company.com",
        "REPORT_LOGO_PATH": "./static/logo.png",
        "REPORT_COMPANY_NAME": "Acme Corp"
      },
      "tools": ["generate_readiness_report", "generate_gap_report", "generate_evidence_report", "generate_executive_summary", "list_generated_reports"]
    },
    "gap-analysis-server": {
      "httpUrl": "http://localhost:5004/mcp",
      "timeout": 30000,
      "trust": false,
      "description": "Identifies compliance gaps and tracks remediation progress",
      "version": "1.0.0",
      "protocol": "2024-11-05",
      "headers": {
        "X-API-Version": "v1",
        "X-Gap-Severity-Filter": "critical,high",
        "X-Service-Name": "gap-analysis-server"
      },
      "env": {
        "GAP_DB": "sqlite:///compliance.db",
        "GAP_AUTO_ASSIGN": "true",
        "GAP_CRITICAL_ALERT_EMAIL": "security@company.com"
      },
      "tools": ["get_all_gaps", "get_critical_gaps", "get_gap_detail", "mark_gap_resolved", "get_gap_summary"]
    },
    "schedule-server": {
      "command": "python",
      "args": ["servers/schedule_server.py", "--reminder-days", "30", "--timezone", "UTC"],
      "description": "Tracks audit deadlines, sends reminders and manages compliance calendar",
      "version": "1.1.0",
      "protocol": "2024-11-05",
      "trust": false,
      "env": {
        "SMTP_HOST": "smtp.gmail.com",
        "SMTP_PORT": "587",
        "SMTP_USE_TLS": "true",
        "ALERT_EMAIL": "compliance@company.com",
        "REMINDER_DAYS_BEFORE": "30,14,7,1",
        "TIMEZONE": "UTC",
        "CALENDAR_SYNC_ENABLED": "true"
      },
      "tools": ["add_deadline", "list_deadlines", "get_overdue_items", "get_upcoming_deadlines", "mark_complete", "send_reminder"]
    }
  }
}
